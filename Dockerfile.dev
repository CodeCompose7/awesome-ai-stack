# syntax=docker/dockerfile:1
# App image for local viewing/editing: Node + pnpm + this repo, running the Astro
# dev server (`pnpm dev`). Both compose files build it:
#   - docker-compose.yml (default) runs it as-is — a self-contained "clone and
#     `docker compose up`" with deps and source baked in, no host files needed.
#   - docker-compose.dev.yml bind-mounts your working tree over it for live edits.
# This is NOT the production build — the site ships as a static build via
# .github/workflows/deploy.yml (GitHub Pages).
FROM node:24-slim

# The docker CLI (client only), copied from the official image. It lets the
# sample "run" wizard drive the *host* Docker daemon through the socket that both
# compose files mount — the same Docker-out-of-Docker setup the dev container
# uses. Harmless if you never use the run wizard.
COPY --from=docker:27-cli /usr/local/bin/docker /usr/local/bin/docker

# git + certs for tooling; pnpm via Corepack, pinned to package.json's
# packageManager so the image matches the dev container and CI.
RUN apt-get update \
    && apt-get install -y --no-install-recommends git ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && corepack enable \
    && corepack prepare pnpm@11.7.0 --activate

WORKDIR /app

# Install dependencies as their own layer (cached until the manifests change).
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile

# Bake the source in so `docker compose up` is self-contained (see .dockerignore
# for what's excluded). docker-compose.dev.yml bind-mounts the host tree over
# this at run time, keeping node_modules from the layer above via an anonymous
# volume — so live edits win there, while the baked copy serves the default mode.
COPY . .

EXPOSE 4321

# astro.config.mjs sets server.host = true, so this listens on 0.0.0.0:4321.
CMD ["pnpm", "dev"]
