# Copy this file to `.env` and add your Anthropic API key.
#   cp .env.sample .env
#
# CrewAI 1.x uses native model providers (not LiteLLM), so this sample installs
# crewai[anthropic] and defaults to Claude. To use another provider, add its
# extra (e.g. crewai[openai]) and change MODEL.
MODEL=anthropic/claude-opus-4-8
ANTHROPIC_API_KEY=
