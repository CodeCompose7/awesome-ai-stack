# Copy this file to `.env` and add your OpenRouter API key.
#   cp .env.sample .env
#
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# LiteLLM model id: openrouter/<vendor>/<model>. Swap the vendor/model freely.
# The default is a `:free` model — runs without purchased credits (rate-limited).
# Paid models (need credits): openrouter/anthropic/claude-opus-4-8, openrouter/openai/gpt-4o
MODEL=openrouter/openai/gpt-oss-120b:free
