# Copy this file to `.env`.
#   cp .env.sample .env
#
# No API key needed — Ollama runs locally. Pull the model first on the host:
#   ollama pull qwen3.5:9b
# Use a tool-capable model and the ollama_chat/ prefix (chat endpoint).
MODEL=ollama_chat/qwen3.5:9b

# Where the Ollama server runs:
#   Local, no Docker:           http://localhost:11434
#   Docker / DooD on the host:  http://host.docker.internal:11434
OLLAMA_API_BASE=http://host.docker.internal:11434
