# Copy this file to `.env` and add your keys.
#   cp .env.sample .env

# LangSmith is a hosted SaaS — get an API key at https://smith.langchain.com
# (Settings -> API Keys). EU users also set LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=aas-langsmith-sample

# The call being traced uses Claude.
ANTHROPIC_API_KEY=
MODEL=claude-opus-4-8
