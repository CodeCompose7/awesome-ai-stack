# Copy this file to `.env` and add your key.
#   cp .env.sample .env
#
# OpenHands routes the model through LiteLLM via LLM_MODEL.

# LiteLLM-style model name. Examples:
#   anthropic/claude-opus-4-8    Anthropic Claude   -> LLM_API_KEY = your Anthropic key
#   openai/gpt-4o                OpenAI             -> LLM_API_KEY = your OpenAI key
LLM_MODEL=anthropic/claude-opus-4-8

# API key for the provider named in LLM_MODEL.
LLM_API_KEY=
