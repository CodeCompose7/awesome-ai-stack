# Dockerfile.dev bakes the whole tree in (`COPY . .`), so keep the context — and
# the image — small: exclude installed deps, build output, caches, VCS metadata,
# and dev-only tooling the running site doesn't need.
node_modules
dist
.astro
.git
.github
.devcontainer
.claude
.aas-cache
.pnpm-store
.pnpm
**/__pycache__
**/*.pyc
# Local secrets in sample folders — never send to the build context.
**/.env
.DS_Store
