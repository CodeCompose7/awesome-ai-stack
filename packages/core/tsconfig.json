{
  "extends": "astro/tsconfigs/strict",
  // Editor-time config. The theme is site-agnostic: `@aas-data/*` resolves to
  // whatever site is being built (the integration sets a Vite alias). For the
  // editor/typechecker we point it at the ai-stack site, the reference
  // consumer — its `astro check` also type-checks these sources (see
  // sites/ai-stack/tsconfig.json).
  "include": ["src/**/*", "../../sites/ai-stack/.astro/types.d.ts"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@aas-data/*": ["../../sites/ai-stack/src/data/*"],
      "@assets/*": ["../../sites/ai-stack/src/assets/*"]
    }
  }
}
