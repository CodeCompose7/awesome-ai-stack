---
import '../styles/global.css';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, type Lang } from '../i18n/ui';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  /** Locale-relative path of this page, e.g. '' (home) or 'stacks/litellm/'. */
  path: string;
}

const { title, lang, path } = Astro.props;
const t = useTranslations(lang);
const description = Astro.props.description ?? t('site.tagline');

const home = getRelativeLocaleUrl(lang, '');
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    {/* Set the theme before first paint to avoid a flash of the wrong theme. */}
    <script is:inline>
      (function () {
        try {
          var pref = localStorage.getItem('theme') || 'system';
          var dark =
            pref === 'dark' ||
            (pref === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.dataset.theme = dark ? 'dark' : 'light';
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <header class="border-b border-[var(--aas-border)]">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4">
        <a href={home} class="text-lg font-bold tracking-tight no-underline">
          ⚡ awesome-agent-stack
        </a>
        <nav class="flex items-center gap-4 text-sm text-[var(--aas-muted)]">
          <a href={`${home}#categories`} class="no-underline hover:text-[var(--aas-text)]">
            {t('nav.browse')}
          </a>
          <a
            href={getRelativeLocaleUrl(lang, 'blog/')}
            class="no-underline hover:text-[var(--aas-text)]"
          >
            {t('nav.blog')}
          </a>
          <a
            href="https://github.com/codecompose7/awesome-agent-stack"
            class="no-underline hover:text-[var(--aas-text)]">GitHub</a
          >
          <ThemeToggle lang={lang} />
          <LanguageSwitcher lang={lang} path={path} />
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-5 py-10">
      <slot />
    </main>

    <footer
      class="border-t border-[var(--aas-border)] py-8 text-center text-sm text-[var(--aas-muted)]"
    >
      <p>
        {t('footer.builtWith')}
        <a href="https://astro.build" class="text-[var(--aas-accent)]">Astro</a>. {
          t('footer.contribute')
        }
      </p>
    </footer>
  </body>
</html>
