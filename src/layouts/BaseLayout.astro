---
import '../styles/global.css';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, languages, type Lang } from '../i18n/ui';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  /** Locale-relative path of this page, e.g. '' (home) or 'stacks/litellm/'. */
  path: string;
  /** Wider container — used by detail pages that have a right-rail TOC. */
  wide?: boolean;
}

const { title, lang, path, wide = false } = Astro.props;
const t = useTranslations(lang);
const description = Astro.props.description ?? t('site.tagline');
const container = wide ? 'max-w-6xl' : 'max-w-5xl';

const home = getRelativeLocaleUrl(lang, '');
const base = import.meta.env.BASE_URL;

// Home URL per locale, for the language auto-detect redirect on the root home.
const localeHomes = Object.fromEntries(
  (Object.keys(languages) as Lang[]).map((c) => [c, getRelativeLocaleUrl(c, '')]),
);
const isDefaultHome = path === '' && lang === 'en';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base.replace(/\/$/, '')}/favicon.svg`} />
    {/* On the root (default-locale) home, send first-time visitors to the
        locale matching their browser — unless they've already picked one (the
        language switcher stores `aas:lang`). Runs before paint, no history entry. */}
    {
      isDefaultHome && (
        <script is:inline define:vars={{ curLang: lang, localeHomes }}>
          (function () {
            try {
              var supported = Object.keys(localeHomes);
              var target = localStorage.getItem('aas:lang');
              if (!target || supported.indexOf(target) === -1) {
                target = null;
                var navs = navigator.languages || [navigator.language || ''];
                for (var i = 0; i < navs.length; i++) {
                  var b = (navs[i] || '').toLowerCase().split('-')[0];
                  if (supported.indexOf(b) !== -1) {
                    target = b;
                    break;
                  }
                }
              }
              if (target && target !== curLang && localeHomes[target]) location.replace(localeHomes[target]);
            } catch (e) {}
          })();
        </script>
      )
    }
    {/* Set the theme before first paint to avoid a flash of the wrong theme. */}
    <script is:inline>
      (function () {
        try {
          var pref = localStorage.getItem('theme') || 'system';
          var dark =
            pref === 'dark' ||
            (pref === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.dataset.theme = dark ? 'dark' : 'light';
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <header class="border-b border-[var(--aas-border)]">
      <div class:list={['mx-auto flex items-center justify-between gap-3 px-5 py-4', container]}>
        <a
          href={home}
          aria-label="awesome-agent-stack"
          class="flex min-w-0 items-center gap-1.5 text-base font-bold tracking-tight whitespace-nowrap no-underline sm:text-lg"
        >
          <span aria-hidden="true">⚡</span>
          {/* Below 600px only the bolt remains, so the narrow header never truncates the wordmark. */}
          <span class="hidden truncate min-[600px]:inline">awesome-agent-stack</span>
        </a>
        {/* On mobile the nav links collapse to icons to fit a narrow header;
            text labels return at the `sm` breakpoint. */}
        <nav class="flex shrink-0 items-center gap-3 text-sm text-[var(--aas-muted)] sm:gap-4">
          <a
            href={`${home}#categories`}
            class="flex items-center no-underline hover:text-[var(--aas-text)]"
            aria-label={t('nav.browse')}
          >
            <svg class="sm:hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
            <span class="hidden sm:inline">{t('nav.browse')}</span>
          </a>
          <a
            href={getRelativeLocaleUrl(lang, 'blog/')}
            class="flex items-center no-underline hover:text-[var(--aas-text)]"
            aria-label={t('nav.blog')}
          >
            <svg class="sm:hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
            <span class="hidden sm:inline">{t('nav.blog')}</span>
          </a>
          <a
            href="https://github.com/codecompose7/awesome-agent-stack"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center no-underline hover:text-[var(--aas-text)]"
            aria-label="GitHub"
          >
            <svg class="sm:hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C4 2 3 2 3 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 2 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            <span class="hidden sm:inline">GitHub</span>
          </a>
          <ThemeToggle lang={lang} />
          <LanguageSwitcher lang={lang} path={path} />
        </nav>
      </div>
    </header>

    <main class:list={['mx-auto px-5 py-10', container]}>
      <slot />
    </main>

    <footer
      class="border-t border-[var(--aas-border)] py-8 text-center text-sm text-[var(--aas-muted)]"
    >
      <p>
        {t('footer.builtWith')}
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--aas-accent)]">Astro</a
        >. {
          t('footer.contribute')
        }
      </p>
    </footer>

    <script>
      // Clicking a heading's "#" anchor copies that section's URL to the
      // clipboard (and updates the address bar) instead of just navigating.
      document.addEventListener('click', (e) => {
        const anchor = (e.target as HTMLElement).closest<HTMLAnchorElement>('a.aas-anchor');
        if (!anchor) return;
        e.preventDefault();
        const hash = anchor.getAttribute('href') ?? '';
        const url = location.origin + location.pathname + location.search + hash;
        history.replaceState(null, '', hash);
        navigator.clipboard?.writeText(url).catch(() => {});
        anchor.classList.add('copied');
        setTimeout(() => anchor.classList.remove('copied'), 1200);
      });

      // Close any open <details> dropdown when clicking outside it (or on Esc).
      // The file-tree folders (.aas-tree-dir) are not dropdowns — leave them be.
      document.addEventListener('click', (e) => {
        const target = e.target as Node;
        document
          .querySelectorAll<HTMLDetailsElement>('details[open]:not(.aas-tree-dir)')
          .forEach((d) => {
            if (!d.contains(target)) d.open = false;
          });
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape')
          document
            .querySelectorAll<HTMLDetailsElement>('details[open]:not(.aas-tree-dir)')
            .forEach((d) => (d.open = false));
      });
    </script>
  </body>
</html>
