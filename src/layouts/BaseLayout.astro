---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A curated stack of tools and services for building AI agents.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body class="min-h-screen">
    <header class="border-b border-[var(--aas-border)]">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4">
        <a href={base} class="text-lg font-bold tracking-tight no-underline">
          ⚡ awesome-agent-stack
        </a>
        <nav class="flex gap-4 text-sm text-[var(--aas-muted)]">
          <a href={`${base}#categories`} class="no-underline hover:text-[var(--aas-text)]">Browse</a>
          <a
            href="https://github.com/codecompose7/awesome-agent-stack"
            class="no-underline hover:text-[var(--aas-text)]"
            >GitHub</a
          >
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-5 py-10">
      <slot />
    </main>

    <footer class="border-t border-[var(--aas-border)] py-8 text-center text-sm text-[var(--aas-muted)]">
      <p>
        Built with <a href="https://astro.build" class="text-[var(--aas-accent)]">Astro</a>.
        Contributions welcome — add a tool by dropping an MDX file.
      </p>
    </footer>
  </body>
</html>
