---
// The samples hub: one card per samples/<folder>/ mini-project, titled and
// excerpted from the locale-appropriate README (README.<lang>.md, falling back
// to README.md). A single-column list, sorted (default newest first) and
// paginated 10 at a time by the shared ListControls. Cards link to the
// per-sample page at sample/<folder>/.
import { getRelativeLocaleUrl } from 'astro:i18n';
import { listProjects } from '../lib/project';
import ListControls from './ListControls.astro';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const PAGE = 10;

// Newest first, then by name — matches ListControls' default 'recent' sort, so
// the server render and the client's initial sort agree (no reorder flash).
const projects = listProjects(lang).sort(
  (a, b) => b.date.localeCompare(a.date) || a.name.localeCompare(b.name, lang),
);

function formatDate(iso: string): string {
  const [y, m, d] = iso.split('-').map(Number);
  if (!y || !m || !d) return iso;
  return new Intl.DateTimeFormat(lang === 'ko' ? 'ko-KR' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(Date.UTC(y, m - 1, d)));
}
---

<section class="py-6">
  <h1 class="text-4xl font-bold tracking-tight">{t('sample.title')}</h1>
  <p class="mt-3 max-w-2xl text-lg text-[var(--aas-muted)]">{t('sample.tagline')}</p>
</section>

{projects.length > 0 && <div class="mt-2"><ListControls lang={lang} /></div>}

<ul class="mt-4 grid gap-3" data-sortgrid data-paginate data-page-size={PAGE}>
  {
    projects.map((p) => (
      <li data-name={p.name} data-date={p.date}>
        <a
          href={getRelativeLocaleUrl(lang, `sample/${p.folder}/`)}
          class="aas-lift flex flex-col gap-1.5 rounded-2xl border border-[var(--aas-border)] bg-[var(--aas-panel)] p-4 no-underline"
        >
          <span class="flex flex-wrap items-baseline gap-x-2.5 gap-y-1">
            <span class="font-semibold text-[var(--aas-text)]">{p.name}</span>
            <code class="rounded bg-[var(--aas-tint)] px-1.5 py-0.5 text-xs text-[var(--aas-muted)]">
              samples/{p.folder}
            </code>
            <span class="text-xs text-[var(--aas-muted)]">{formatDate(p.date)}</span>
          </span>
          {p.excerpt && (
            <span class="line-clamp-2 text-sm leading-relaxed text-[var(--aas-muted)]">{p.excerpt}</span>
          )}
        </a>
      </li>
    ))
  }
</ul>

<nav data-pager aria-label="Pagination" class="mt-8 flex flex-wrap items-center justify-center gap-1.5"></nav>
