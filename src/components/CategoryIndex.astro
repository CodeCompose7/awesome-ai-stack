---
import { getRelativeLocaleUrl } from 'astro:i18n';
import StackCard from './StackCard.astro';
import Breadcrumb from './Breadcrumb.astro';
import FilterControls from './FilterControls.astro';
import { categoryMap, childrenOf, pathOf } from '../data/categories';
import { getStacksByCategory, slugOf, type StackEntry } from '../lib/stacks';
import { pricingTags } from '../lib/pricing';
import { useTranslations, pricingLabels, licenseLabel, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  id: string;
}

const { lang, id } = Astro.props;
const t = useTranslations(lang);
const node = categoryMap.get(id)!;
const catUrl = (cid: string) => getRelativeLocaleUrl(lang, `categories/${cid}/`);

// Breadcrumb: All tools › ancestors… › current (current is not a link).
const path = pathOf(id);
const crumbs = [
  { label: t('detail.allTools'), href: getRelativeLocaleUrl(lang, '') },
  ...path.map((c, i) => ({
    label: c.label[lang],
    href: i === path.length - 1 ? undefined : catUrl(c.id),
  })),
];

const children = childrenOf(id);
// Stacks attached directly to this node (vs. nested under a subcategory).
const direct = (await getStacksByCategory(lang, id)).filter((s) => s.data.category === id);
// Each child subcategory with its own rolled-up stacks.
const childGroups = await Promise.all(
  children.map(async (c) => ({ cat: c, items: await getStacksByCategory(lang, c.id) })),
);

// Filter facets, derived from every tool shown on this page (direct + subtrees).
const allEntries = [...direct, ...childGroups.flatMap((g) => g.items)];
const pricingOrder = ['completely-free', 'open-source', 'free-tier', 'paid', 'free'];
const usedPricing = new Set<string>(allEntries.flatMap((e) => pricingTags(e.data.pricing)));
const langSet = new Set(
  allEntries.flatMap((e) =>
    (e.data.language ?? '')
      .split('/')
      .map((s) => s.trim())
      .filter(Boolean),
  ),
);
const facets = [
  {
    key: 'pricing',
    label: t('detail.pricing'),
    options: pricingOrder
      .filter((p) => usedPricing.has(p))
      .map((p) => ({ value: p, label: pricingLabels[lang][p] ?? p })),
  },
  {
    key: 'license',
    label: t('detail.license'),
    options: [...new Set(allEntries.map((e) => e.data.license).filter(Boolean))]
      .sort()
      .map((l) => ({ value: l as string, label: licenseLabel(lang, l as string) })),
  },
  {
    key: 'language',
    label: t('detail.language'),
    options: [...langSet].sort().map((l) => ({ value: l, label: l })),
  },
];

const cardProps = (e: StackEntry) => ({
  slug: slugOf(e),
  lang,
  name: e.data.name,
  formerNames: e.data.formerNames,
  description: e.data.description,
  tags: e.data.tags,
  pricing: e.data.pricing,
  license: e.data.license,
  language: e.data.language,
  category: e.data.category,
  logo: e.data.logo,
  logoDark: e.data.logoDark,
  repo: e.data.repo,
  version: e.data.version,
  deprecated: e.data.deprecated,
});
---

<section class="py-6">
  <Breadcrumb segments={crumbs} />
  <h1 class="mt-3 text-3xl font-bold tracking-tight">{node.label[lang]}</h1>
  <p class="mt-3 max-w-3xl leading-relaxed text-[var(--aas-muted)]">
    {node.detail?.[lang] ?? node.description[lang]}
  </p>
</section>

{/* Search · filter · sort controls (client-side, URL-synced) */}
<div class="mb-8">
  <FilterControls lang={lang} facets={facets} />
</div>

{/* Tools sitting directly on this node (no subcategory). */}
{
  direct.length > 0 && (
    <div data-section>
      <div class="grid gap-4 sm:grid-cols-2" data-grid>
        {direct.map((e) => (
          <StackCard {...cardProps(e)} />
        ))}
      </div>
    </div>
  )
}

{/* One section per subcategory, each rolling up its own subtree. */}
<div class="mt-8 space-y-12">
  {
    childGroups
      .filter((g) => g.items.length > 0)
      .map((g) => (
        <div data-section>
          <div class="pb-1">
            <h2 class="text-2xl font-semibold">
              <a href={catUrl(g.cat.id)} class="text-[var(--aas-text)] no-underline hover:text-[var(--aas-accent)]">
                {g.cat.label[lang]}
                <span class="text-[var(--aas-muted)]"> &nearr;</span>
              </a>
            </h2>
            <p class="mt-1 text-sm text-[var(--aas-muted)]">{g.cat.description[lang]}</p>
          </div>
          <div class="mt-5 grid gap-4 sm:grid-cols-2" data-grid>
            {g.items.map((e) => (
              <StackCard {...cardProps(e)} />
            ))}
          </div>
        </div>
      ))
  }
</div>
