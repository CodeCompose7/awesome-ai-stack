---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { assetSrc } from '../lib/asset';
import type { Lang } from '../i18n/ui';

interface Props {
  slug: string;
  lang: Lang;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  image?: string;
  imageAlt?: string;
}

const { slug, lang, title, description, date, tags, image, imageAlt } = Astro.props;
const href = getRelativeLocaleUrl(lang, `blog/${slug}/`);
const dateStr = date.toISOString().slice(0, 10);
const imgSrc = assetSrc(image);
---

<a
  href={href}
  class="aas-lift block overflow-hidden rounded-3xl border border-[var(--aas-border)] bg-[var(--aas-panel)] no-underline"
>
  {imgSrc && <img src={imgSrc} alt={imageAlt ?? title} class="aspect-[16/9] w-full object-cover" loading="lazy" />}
  <div class="p-5">
    <time datetime={dateStr} class="text-xs text-[var(--aas-muted)]">{dateStr}</time>
    <h3 class="mt-1 text-lg font-semibold text-[var(--aas-text)]">{title}</h3>
    <p class="mt-2 text-sm leading-relaxed text-[var(--aas-muted)]">{description}</p>
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.slice(0, 4).map((tag) => (
            <span class="rounded-full border border-[var(--aas-border)] px-2 py-0.5 text-xs text-[var(--aas-muted)]">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </div>
</a>
