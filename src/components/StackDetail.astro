---
import { render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { categoryMap } from '../data/categories';
import { useTranslations, type Lang } from '../i18n/ui';
import { slugOf, type StackEntry } from '../lib/stacks';
import { getArticlesForTool, articleSlugOf } from '../lib/articles';
import ToolAvatar from './ToolAvatar.astro';
import ToolMeta from './ToolMeta.astro';
import DetailTabs from './DetailTabs.astro';
import CodeSamples from './CodeSamples.astro';
import MermaidLoader from './MermaidLoader.astro';
import Toc from './Toc.astro';
import { getRepoStats } from '../lib/github';

interface Props {
  entry: StackEntry;
  lang: Lang;
}

const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const { Content, headings } = await render(entry);
const data = entry.data;
const category = categoryMap.get(data.category);

// Right-rail table of contents: body headings, h2–h3 only.
const tocItems = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

// Backlinks: writing that references this tool (computed reverse lookup).
const relatedArticles = await getArticlesForTool(lang, slugOf(entry));

// Live GitHub stats (build-time), with the manual `version` as fallback.
const stats = await getRepoStats(data.repo);
const displayVersion = stats?.version ?? data.version;

const links = [
  data.website && { label: t('detail.website'), href: data.website },
  data.repo && { label: t('detail.repository'), href: data.repo },
  data.docs && { label: t('detail.docs'), href: data.docs },
].filter(Boolean) as { label: string; href: string }[];

const hasSamples = data.samples.length > 0;
---

<a href={getRelativeLocaleUrl(lang, '')} class="text-sm text-[var(--aas-accent)] no-underline"
  >&larr; {t('detail.allTools')}</a
>

<header class="mt-4 border-b border-[var(--aas-border)] pb-6">
  <div class="flex items-center gap-4">
    <ToolAvatar name={data.name} logo={data.logo} size={56} />
    <div>
      {category && <p class="text-sm text-[var(--aas-muted)]">{category.label[lang]}</p>}
      <h1 class="text-3xl font-bold tracking-tight">{data.name}</h1>
    </div>
  </div>
  <p class="mt-3 max-w-2xl text-lg text-[var(--aas-muted)]">{data.description}</p>

  <div class="mt-4 flex flex-wrap gap-3 text-sm">
    {
      links.map((l) => (
        <a
          href={l.href}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-[var(--aas-border)] px-3 py-1.5 text-[var(--aas-accent)] no-underline hover:border-[var(--aas-accent)]"
        >
          {l.label} &nearr;
        </a>
      ))
    }
  </div>

  <ToolMeta
    lang={lang}
    pricing={data.pricing}
    license={data.license}
    stars={stats?.stars}
    version={displayVersion}
    class="mt-5"
  />

  {
    data.language && (
      <p class="mt-3 text-sm text-[var(--aas-muted)]">
        {t('detail.language')}: <span class="text-[var(--aas-text)]">{data.language}</span>
      </p>
    )
  }
</header>

<div class="mt-8 lg:grid lg:grid-cols-[minmax(0,1fr)_13rem] lg:items-start lg:gap-10">
  <div class="min-w-0">
    {
      hasSamples ? (
        <DetailTabs overviewLabel={t('tab.overview')} codeLabel={t('tab.code')}>
          <article slot="overview" class="prose max-w-none">
            <Content />
          </article>
          <div slot="code">
            <CodeSamples samples={data.samples} lang={lang} />
          </div>
        </DetailTabs>
      ) : (
        <article class="prose max-w-none">
          <Content />
        </article>
      )
    }
  </div>

  {/* Sticky right-rail TOC; swaps with the active tab. */}
  <aside class="mt-8 hidden lg:mt-0 lg:block">
    <div class="sticky top-6 space-y-4">
      <div data-toc="overview">
        <Toc items={tocItems} title={t('toc.onThisPage')} />
      </div>
      {
        hasSamples && (
          <nav data-toc="code" class="hidden text-sm" aria-label={t('toc.versions')}>
            <p class="mb-2 text-xs font-semibold tracking-wide text-[var(--aas-muted)] uppercase">
              {t('toc.versions')}
            </p>
            <ul class="border-l border-[var(--aas-border)]">
              {data.samples.map((s, i) => (
                <li>
                  <button
                    type="button"
                    data-toc-version={i}
                    aria-current={i === 0 ? 'true' : 'false'}
                    class="-ml-px block w-full border-l-2 border-transparent py-1 pl-3 text-left text-[var(--aas-muted)] hover:border-[var(--aas-accent)] hover:text-[var(--aas-text)] aria-[current=true]:border-[var(--aas-accent)] aria-[current=true]:text-[var(--aas-text)]"
                  >
                    {s.version}
                  </button>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </div>
  </aside>
</div>

{hasSamples && <MermaidLoader />}

<script>
  // Sync the right-rail TOC with the active tab, and let the version list drive
  // the code-sample selector.
  document.addEventListener('aas:tabchange', (e) => {
    const id = (e as CustomEvent<{ id: string }>).detail.id;
    document
      .querySelectorAll<HTMLElement>('[data-toc]')
      .forEach((el) => el.classList.toggle('hidden', el.dataset.toc !== id));
  });

  const select = document.querySelector<HTMLSelectElement>('[data-sample-select]');
  const versionBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-toc-version]'));
  const markActive = (i: string) =>
    versionBtns.forEach((b) => b.setAttribute('aria-current', String(b.dataset.tocVersion === i)));

  versionBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      if (select) {
        select.value = btn.dataset.tocVersion ?? '0';
        select.dispatchEvent(new Event('change'));
      }
      markActive(btn.dataset.tocVersion ?? '0');
    });
  });
  // Keep the version list in sync when the <select> is used directly.
  select?.addEventListener('change', () => markActive(select.value));
</script>

{
  relatedArticles.length > 0 && (
    <aside class="mt-10 border-t border-[var(--aas-border)] pt-6">
      <h2 class="text-sm font-semibold tracking-wide text-[var(--aas-muted)] uppercase">
        {t('detail.relatedWriting')}
      </h2>
      <ul class="mt-3 space-y-2">
        {relatedArticles.map((a) => (
          <li>
            <a
              href={getRelativeLocaleUrl(lang, `blog/${articleSlugOf(a)}/`)}
              class="text-[var(--aas-accent)] no-underline hover:underline"
            >
              {a.data.title}
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}
