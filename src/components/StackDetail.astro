---
import { render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { categoryMap } from '../data/categories';
import { useTranslations, type Lang } from '../i18n/ui';
import { slugOf, type StackEntry } from '../lib/stacks';
import { getArticlesForTool, articleSlugOf } from '../lib/articles';
import ToolAvatar from './ToolAvatar.astro';
import ToolMeta from './ToolMeta.astro';

interface Props {
  entry: StackEntry;
  lang: Lang;
}

const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(entry);
const data = entry.data;
const category = categoryMap.get(data.category);

// Backlinks: writing that references this tool (computed reverse lookup).
const relatedArticles = await getArticlesForTool(lang, slugOf(entry));

const links = [
  data.website && { label: t('detail.website'), href: data.website },
  data.repo && { label: t('detail.repository'), href: data.repo },
  data.docs && { label: t('detail.docs'), href: data.docs },
].filter(Boolean) as { label: string; href: string }[];
---

<a href={getRelativeLocaleUrl(lang, '')} class="text-sm text-[var(--aas-accent)] no-underline"
  >&larr; {t('detail.allTools')}</a
>

<header class="mt-4 border-b border-[var(--aas-border)] pb-6">
  <div class="flex items-center gap-4">
    <ToolAvatar name={data.name} logo={data.logo} size={56} />
    <div>
      {category && <p class="text-sm text-[var(--aas-muted)]">{category.label[lang]}</p>}
      <h1 class="text-3xl font-bold tracking-tight">{data.name}</h1>
    </div>
  </div>
  <p class="mt-3 max-w-2xl text-lg text-[var(--aas-muted)]">{data.description}</p>

  <div class="mt-4 flex flex-wrap gap-3 text-sm">
    {
      links.map((l) => (
        <a
          href={l.href}
          class="rounded-lg border border-[var(--aas-border)] px-3 py-1.5 text-[var(--aas-accent)] no-underline hover:border-[var(--aas-accent)]"
        >
          {l.label} &nearr;
        </a>
      ))
    }
  </div>

  <ToolMeta lang={lang} pricing={data.pricing} license={data.license} class="mt-5" />

  {
    data.language && (
      <p class="mt-3 text-sm text-[var(--aas-muted)]">
        {t('detail.language')}: <span class="text-[var(--aas-text)]">{data.language}</span>
      </p>
    )
  }
</header>

<article class="prose mt-8 max-w-none">
  <Content />
</article>

{
  relatedArticles.length > 0 && (
    <aside class="mt-10 border-t border-[var(--aas-border)] pt-6">
      <h2 class="text-sm font-semibold tracking-wide text-[var(--aas-muted)] uppercase">
        {t('detail.relatedWriting')}
      </h2>
      <ul class="mt-3 space-y-2">
        {relatedArticles.map((a) => (
          <li>
            <a
              href={getRelativeLocaleUrl(lang, `blog/${articleSlugOf(a)}/`)}
              class="text-[var(--aas-accent)] no-underline hover:underline"
            >
              {a.data.title}
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}
