---
import { render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getStacks, slugOf, type StackEntry } from '../lib/stacks';
import { getArticles, articleSlugOf, type ArticleEntry } from '../lib/articles';
import { getConcepts, conceptSlugOf, type ConceptEntry } from '../lib/concepts';
import { categoryMap } from '../data/categories';
import { useTranslations, type Lang } from '../i18n/ui';
import ToolAvatar from './ToolAvatar.astro';
import MermaidLoader from './MermaidLoader.astro';

interface Props {
  entry: ConceptEntry;
  lang: Lang;
}

const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(entry);
const data = entry.data;
const bodyHasMermaid = (entry.body ?? '').includes('```mermaid');

// Resolve the role-grouped tool slugs to their stack entries.
const stacks = await getStacks(lang);
const stackBySlug = new Map(stacks.map((s) => [slugOf(s), s]));
const toolGroups = data.tools
  .map((g) => ({
    role: g.role,
    tools: g.tools.map((sl) => stackBySlug.get(sl)).filter(Boolean) as StackEntry[],
  }))
  .filter((g) => g.tools.length > 0);

// Related articles + related concepts (resolved from slugs).
const articles = await getArticles(lang);
const articleBySlug = new Map(articles.map((a) => [articleSlugOf(a), a]));
const relatedArticles = data.articles
  .map((sl) => articleBySlug.get(sl))
  .filter(Boolean) as ArticleEntry[];

const concepts = await getConcepts(lang);
const conceptBySlug = new Map(concepts.map((c) => [conceptSlugOf(c), c]));
const relatedConcepts = data.related
  .map((sl) => conceptBySlug.get(sl))
  .filter(Boolean) as ConceptEntry[];

const sectionHead = 'text-sm font-semibold tracking-wide text-[var(--aas-muted)] uppercase';
---

<a
  href={getRelativeLocaleUrl(lang, 'concepts/')}
  class="text-sm text-[var(--aas-accent)] no-underline">&larr; {t('concept.backToConcepts')}</a
>

<header class="mt-4 pb-6">
  <h1 class="text-3xl font-bold tracking-tight">{data.title}</h1>
  <p class="mt-2 max-w-2xl text-lg text-[var(--aas-muted)]">{data.description}</p>
</header>

<article class="prose max-w-none">
  <Content />
</article>

{
  toolGroups.length > 0 && (
    <section class="mt-10 border-t border-[var(--aas-border)] pt-6">
      <h2 class={sectionHead}>{t('concept.usedTools')}</h2>
      <div class="mt-4 space-y-5">
        {toolGroups.map((g) => (
          <div>
            <h3 class="text-sm font-semibold text-[var(--aas-text)]">{g.role}</h3>
            <div class="mt-2 grid gap-3 sm:grid-cols-2">
              {g.tools.map((e) => (
                <a
                  href={getRelativeLocaleUrl(lang, `stacks/${slugOf(e)}/`)}
                  class="aas-lift flex items-center gap-3 rounded-xl border border-[var(--aas-border)] bg-[var(--aas-panel)] p-3 no-underline"
                >
                  <ToolAvatar name={e.data.name} logo={e.data.logo} logoDark={e.data.logoDark} category={e.data.category} size={36} />
                  <div class="min-w-0">
                    <span class="block truncate font-semibold text-[var(--aas-text)]">{e.data.name}</span>
                    <span class="block truncate text-xs text-[var(--aas-muted)]">
                      {categoryMap.get(e.data.category)?.label[lang]}
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )
}

{
  relatedArticles.length > 0 && (
    <aside class="mt-10 border-t border-[var(--aas-border)] pt-6">
      <h2 class={sectionHead}>{t('detail.relatedWriting')}</h2>
      <ul class="mt-3 space-y-2">
        {relatedArticles.map((a) => (
          <li>
            <a
              href={getRelativeLocaleUrl(lang, `blog/${articleSlugOf(a)}/`)}
              class="text-[var(--aas-accent)] no-underline hover:underline"
            >
              {a.data.title}
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}

{
  relatedConcepts.length > 0 && (
    <aside class="mt-10 border-t border-[var(--aas-border)] pt-6">
      <h2 class={sectionHead}>{t('concept.relatedConcepts')}</h2>
      <ul class="mt-3 space-y-2">
        {relatedConcepts.map((c) => (
          <li>
            <a
              href={getRelativeLocaleUrl(lang, `concepts/${conceptSlugOf(c)}/`)}
              class="text-[var(--aas-accent)] no-underline hover:underline"
            >
              {c.data.title}
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}

{bodyHasMermaid && <MermaidLoader />}
