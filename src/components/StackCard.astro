---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Lang } from '../i18n/ui';
import { getRepoStats } from '../lib/github';
import ToolAvatar from './ToolAvatar.astro';
import ToolMeta from './ToolMeta.astro';

interface Props {
  slug: string;
  lang: Lang;
  name: string;
  description: string;
  tags: string[];
  pricing: string[];
  license?: string;
  language?: string;
  logo?: string;
  repo?: string;
  version?: string;
}

const { slug, lang, name, description, tags, pricing, license, language, logo, repo, version } =
  Astro.props;
const href = getRelativeLocaleUrl(lang, `stacks/${slug}/`);

// Live stats from GitHub (build-time), with the manual `version` as fallback.
const stats = await getRepoStats(repo);
const displayVersion = stats?.version ?? version;
---

{/* The card is a container, not a link: the name is the stretched primary link
   (its ::after covers the whole card), while tag links sit above it (z-10) so
   they remain individually clickable. */}
<div
  class="aas-lift relative flex flex-col rounded-xl border border-[var(--aas-border)] bg-[var(--aas-panel)] p-5"
>
  <div class="flex min-w-0 items-center gap-3">
    <ToolAvatar name={name} logo={logo} size={40} />
    <h3 class="truncate text-base font-semibold text-[var(--aas-text)]">
      <a href={href} class="no-underline after:absolute after:inset-0 after:content-['']">{name}</a>
    </h3>
  </div>
  <p class="mt-2 text-sm leading-relaxed text-[var(--aas-muted)]">{description}</p>

  {/* Facts: stars · version · pricing · license */}
  <ToolMeta
    lang={lang}
    pricing={pricing}
    license={license}
    language={language}
    stars={stats?.stars}
    version={displayVersion}
    released={stats?.releasedAt?.slice(0, 10)}
    class="mt-3"
  />

  {/* Keyword tags — clickable links to per-tag pages, above the card overlay */}
  {
    tags.length > 0 && (
      <div class="relative z-10 mt-auto flex flex-wrap gap-x-3 gap-y-1 pt-3 text-xs text-[var(--aas-muted)]">
        {tags.slice(0, 4).map((tag) => (
          <a
            href={getRelativeLocaleUrl(lang, `tags/${tag}/`)}
            class="no-underline opacity-80 hover:text-[var(--aas-accent)] hover:opacity-100"
          >
            #{tag}
          </a>
        ))}
      </div>
    )
  }
</div>
