---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Lang } from '../i18n/ui';
import ToolAvatar from './ToolAvatar.astro';
import ToolMeta from './ToolMeta.astro';

interface Props {
  slug: string;
  lang: Lang;
  name: string;
  description: string;
  tags: string[];
  pricing: string[];
  license?: string;
  logo?: string;
}

const { slug, lang, name, description, tags, pricing, license, logo } = Astro.props;
const href = getRelativeLocaleUrl(lang, `stacks/${slug}/`);
---

<a
  href={href}
  class="block rounded-xl border border-[var(--aas-border)] bg-[var(--aas-panel)] p-5 no-underline transition-colors hover:border-[var(--aas-accent)]"
>
  <div class="flex min-w-0 items-center gap-3">
    <ToolAvatar name={name} logo={logo} size={40} />
    <h3 class="truncate text-base font-semibold text-[var(--aas-text)]">{name}</h3>
  </div>
  <p class="mt-2 text-sm leading-relaxed text-[var(--aas-muted)]">{description}</p>

  <ToolMeta lang={lang} pricing={pricing} license={license} class="mt-3" />

  {
    tags.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1.5">
        {tags.slice(0, 4).map((tag) => (
          <span class="rounded-full border border-[var(--aas-border)] px-2 py-0.5 text-xs text-[var(--aas-muted)]">
            {tag}
          </span>
        ))}
      </div>
    )
  }
</a>
