---
interface Props {
  overviewLabel: string;
  codeLabel: string;
}

const { overviewLabel, codeLabel } = Astro.props;
const tabClass =
  'aas-tab cursor-pointer rounded-lg px-3 py-1.5 text-sm font-medium text-[var(--aas-muted)] hover:text-[var(--aas-text)]';
---

<div data-tabs>
  <div role="tablist" class="inline-flex gap-1 rounded-xl bg-[var(--aas-tint)] p-1">
    <button type="button" data-tab="overview" class={tabClass} aria-selected="true">
      {overviewLabel}
    </button>
    <button type="button" data-tab="code" class={tabClass} aria-selected="false">
      {codeLabel}
    </button>
  </div>

  <div data-panel="overview" class="mt-6">
    <slot name="overview" />
  </div>
  <div data-panel="code" class="mt-6 hidden">
    <slot name="code" />
  </div>

  {/* Pre-paint: pick the tab from the hash using inline display styles, which
      apply before the stylesheet loads (so it works in dev too, where Vite
      injects CSS after first paint). The module script below normalizes this. */}
  <script is:inline>
    (function () {
      var root = document.currentScript.parentElement;
      var hash = location.hash;
      var wantCode = hash === '#code';
      if (!wantCode && hash && hash !== '#overview') {
        var cp = root.querySelector('[data-panel="code"]');
        try {
          if (cp && cp.querySelector(hash)) wantCode = true;
        } catch (e) {}
      }
      if (wantCode) {
        root.querySelector('[data-panel="overview"]').style.display = 'none';
        root.querySelector('[data-panel="code"]').style.display = 'block';
        root.querySelectorAll('[data-tab]').forEach(function (t) {
          t.setAttribute('aria-selected', String(t.dataset.tab === 'code'));
        });
      }
    })();
  </script>
</div>

<style>
  .aas-tab[aria-selected='true'] {
    background: var(--aas-panel);
    color: var(--aas-text);
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.08);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-tabs]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-panel]'));

    function show(id: string, updateHash: boolean) {
      tabs.forEach((t) => t.setAttribute('aria-selected', String(t.dataset.tab === id)));
      panels.forEach((p) => {
        p.style.removeProperty('display'); // clear the pre-paint inline style
        p.classList.toggle('hidden', p.dataset.panel !== id);
      });
      document.dispatchEvent(new CustomEvent('aas:tabchange', { detail: { id } }));
      (window as unknown as { __aasRenderMermaid?: () => void }).__aasRenderMermaid?.();
      // replaceState updates the URL without scrolling or stacking history.
      if (updateHash) history.replaceState(null, '', '#' + id);
    }

    tabs.forEach((tab) => tab.addEventListener('click', () => show(tab.dataset.tab!, true)));

    // Restore the tab from the URL hash so refresh and direct links keep it.
    // `#code` selects the Code tab; a hash that matches an id inside the code
    // panel (e.g. a sample heading) does too. Everything else stays on Overview.
    const raw = decodeURIComponent(location.hash.slice(1));
    let initial = 'overview';
    if (raw === 'code') {
      initial = 'code';
    } else if (raw && raw !== 'overview') {
      const codePanel = root.querySelector('[data-panel="code"]');
      const esc = window.CSS && CSS.escape ? CSS.escape(raw) : raw;
      try {
        if (codePanel && codePanel.querySelector('#' + esc)) initial = 'code';
      } catch {
        /* invalid selector — ignore */
      }
    }
    // Normalize to class-based visibility (also clears the pre-paint inline
    // styles). Run for both tabs so the inline overrides never linger.
    show(initial, false);
    if (initial === 'code' && raw && raw !== 'code') {
      // Sample-heading ids look like `s<index>-...`; select that version first.
      const m = raw.match(/^s(\d+)-/);
      if (m) {
        const sel = document.querySelector<HTMLSelectElement>('[data-sample-select]');
        if (sel) {
          sel.value = m[1];
          sel.dispatchEvent(new Event('change'));
        }
      }
      document.getElementById(raw)?.scrollIntoView();
    }
  });
</script>
