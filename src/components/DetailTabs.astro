---
interface Props {
  overviewLabel: string;
  codeLabel: string;
}

const { overviewLabel, codeLabel } = Astro.props;
const tabClass =
  'aas-tab border-b-2 px-1 pb-2 text-sm font-medium border-transparent text-[var(--aas-muted)] hover:text-[var(--aas-text)]';
---

<div data-tabs>
  <div role="tablist" class="flex gap-5 border-b border-[var(--aas-border)]">
    <button type="button" data-tab="overview" class={tabClass} aria-selected="true">
      {overviewLabel}
    </button>
    <button type="button" data-tab="code" class={tabClass} aria-selected="false">
      {codeLabel}
    </button>
  </div>

  <div data-panel="overview" class="mt-6">
    <slot name="overview" />
  </div>
  <div data-panel="code" class="mt-6 hidden">
    <slot name="code" />
  </div>
</div>

<style>
  .aas-tab[aria-selected='true'] {
    border-color: var(--aas-accent);
    color: var(--aas-text);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-tabs]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-panel]'));

    function show(id: string, updateHash: boolean) {
      tabs.forEach((t) => t.setAttribute('aria-selected', String(t.dataset.tab === id)));
      panels.forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== id));
      document.dispatchEvent(new CustomEvent('aas:tabchange', { detail: { id } }));
      (window as unknown as { __aasRenderMermaid?: () => void }).__aasRenderMermaid?.();
      // replaceState updates the URL without scrolling or stacking history.
      if (updateHash) history.replaceState(null, '', '#' + id);
    }

    tabs.forEach((tab) => tab.addEventListener('click', () => show(tab.dataset.tab!, true)));

    // Restore the tab from the URL hash so refresh and direct links keep it.
    // `#code` selects the Code tab; a hash that matches an id inside the code
    // panel (e.g. a sample heading) does too. Everything else stays on Overview.
    const raw = decodeURIComponent(location.hash.slice(1));
    let initial = 'overview';
    if (raw === 'code') {
      initial = 'code';
    } else if (raw && raw !== 'overview') {
      const codePanel = root.querySelector('[data-panel="code"]');
      const esc = window.CSS && CSS.escape ? CSS.escape(raw) : raw;
      try {
        if (codePanel && codePanel.querySelector('#' + esc)) initial = 'code';
      } catch {
        /* invalid selector — ignore */
      }
    }
    if (initial === 'code') {
      show('code', false);
      if (raw && raw !== 'code') document.getElementById(raw)?.scrollIntoView();
    }
    // JS now controls visibility via the `hidden` class; drop the pre-paint
    // override so tab clicks aren't blocked by it.
    delete document.documentElement.dataset.tabInit;
  });
</script>
