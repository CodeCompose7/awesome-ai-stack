---
import ArticleCard from './ArticleCard.astro';
import { getArticles, articleSlugOf } from '../lib/articles';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const articles = await getArticles(lang);
---

<section class="py-6">
  <h1 class="text-4xl font-bold tracking-tight">{t('blog.title')}</h1>
  <p class="mt-3 max-w-2xl text-lg text-[var(--aas-muted)]">{t('blog.tagline')}</p>
</section>

{
  articles.length === 0 ? (
    <p class="mt-8 text-[var(--aas-muted)]">{t('blog.empty')}</p>
  ) : (
    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      {articles.map((a) => (
        <ArticleCard
          slug={articleSlugOf(a)}
          lang={lang}
          title={a.data.title}
          description={a.data.description}
          date={a.data.date}
          tags={a.data.tags}
        />
      ))}
    </div>
  )
}
