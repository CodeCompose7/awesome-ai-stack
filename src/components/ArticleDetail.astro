---
import { render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getStacks, slugOf } from '../lib/stacks';
import { categoryMap } from '../data/categories';
import { Image } from 'astro:assets';
import { useTranslations, type Lang } from '../i18n/ui';
import { formatDate } from '../lib/dates';
import ToolAvatar from './ToolAvatar.astro';
import TocRail from './TocRail.astro';
import MermaidLoader from './MermaidLoader.astro';
import { renderProjects } from '../lib/project';
import type { RelatedTool } from './ProjectRelatedTools.astro';
import type { ArticleEntry } from '../lib/articles';

interface Props {
  entry: ArticleEntry;
  lang: Lang;
}

const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const { Content, headings } = await render(entry);
const data = entry.data;
const dateStr = data.date.toISOString().slice(0, 10);
const updatedStr = data.updated?.toISOString().slice(0, 10);
const tocItems = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
// Articles may embed Mermaid diagrams (and a <SampleProject/> whose README can
// too); load the client renderer when the body uses any.
const bodyHasMermaid = (entry.body ?? '').includes('```mermaid');

// Forward links: resolve referenced tool slugs to their stack entries so they
// render as the same cards used by the "related tools" section.
const stacks = await getStacks(lang);
const bySlug = new Map(stacks.map((s) => [slugOf(s), s]));
const referenced = data.tools
  .map((slug) => bySlug.get(slug))
  .filter(Boolean) as NonNullable<ReturnType<typeof bySlug.get>>[];

// Optional embedded sample (samples/<folder>/): its file list + related tools
// go in the right rail, mirroring a stack's implementation tab. The body still
// renders the viewer via <SampleProject folder="…"/>; both share the folder, so
// the rail's file buttons wire to the body viewer (matched document-wide).
const projectSpec = data.project
  ? typeof data.project === 'string'
    ? { folder: data.project, related: [] as string[] }
    : { folder: data.project.folder, related: data.project.related }
  : null;
const renderedProject = projectSpec ? (await renderProjects([projectSpec.folder], lang))[0] : undefined;
function resolveTool(slug: string): RelatedTool {
  const e = bySlug.get(slug);
  if (!e) return { slug, name: slug, registered: false };
  return {
    slug,
    name: e.data.name,
    registered: true,
    logo: e.data.logo,
    logoDark: e.data.logoDark,
    category: e.data.category,
    deprecated: e.data.deprecated,
  };
}
const relatedTools = projectSpec ? projectSpec.related.map(resolveTool) : [];
const projectFiles = renderedProject
  ? { folder: renderedProject.folder, files: renderedProject.files }
  : undefined;
---

<div class="aas-doc">
<div class="aas-doc-main">
<a href={getRelativeLocaleUrl(lang, 'blog/')} class="text-sm text-[var(--aas-accent)] no-underline"
  >&larr; {t('article.backToBlog')}</a
>

<header class="mt-4 border-b border-[var(--aas-border)] pb-6">
  <p class="text-sm text-[var(--aas-muted)]">
    <time datetime={dateStr}>{formatDate(data.date, lang)}</time>
    {data.version && <span> · {t('meta.docVersion')} {data.version}</span>}
    {data.updated && updatedStr !== dateStr && (
      <span>
        {' '}
        · {t('meta.updated')} <time datetime={updatedStr}>{formatDate(data.updated, lang)}</time>
      </span>
    )}
  </p>
  <h1 class="mt-1 text-3xl font-bold tracking-tight">{data.title}</h1>
  <p class="mt-2 max-w-2xl text-lg whitespace-pre-line text-[var(--aas-muted)]">{data.description}</p>
  {
    data.image && (
      <Image
        src={data.image}
        alt={data.imageAlt ?? data.title}
        class="mt-5 aspect-[2/1] w-full rounded-2xl border border-[var(--aas-border)] object-cover"
      />
    )
  }

  {
    referenced.length > 0 && (
      <div class="mt-5">
        <span class="text-xs tracking-wide text-[var(--aas-muted)] uppercase">
          {t('article.referencedTools')}
        </span>
        <div class="mt-2 grid gap-3 sm:grid-cols-2">
          {referenced.map((e) => (
            <a
              href={getRelativeLocaleUrl(lang, `stacks/${slugOf(e)}/`)}
              target="_blank"
              rel="noopener noreferrer"
              class="aas-lift flex items-center gap-3 rounded-xl border border-[var(--aas-border)] bg-[var(--aas-panel)] p-3 no-underline"
            >
              <ToolAvatar name={e.data.name} logo={e.data.logo} logoDark={e.data.logoDark} category={e.data.category} size={36} />
              <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <span class="truncate font-semibold text-[var(--aas-text)]">{e.data.name}</span>
                  {e.data.deprecated && (
                    <span class="aas-deprecated shrink-0 rounded px-1.5 py-0.5 text-[0.65rem]">
                      {t('meta.deprecated')}
                    </span>
                  )}
                </div>
                <div class="truncate text-xs text-[var(--aas-muted)]">
                  {categoryMap.get(e.data.category)?.label[lang]}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )
  }
</header>

<article class="prose mt-8 max-w-none">
  <Content />
</article>
</div>

<TocRail lang={lang} items={tocItems} relatedTools={relatedTools} projectFiles={projectFiles} />
</div>

{bodyHasMermaid && <MermaidLoader />}
