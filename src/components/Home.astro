---
import StackCard from './StackCard.astro';
import { categories } from '../data/categories';
import { getStacks, slugOf } from '../lib/stacks';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const entries = await getStacks(lang);

// Group entries by their category id for sectioned rendering.
const byCategory = (categoryId: string) =>
  entries
    .filter((e) => e.data.category === categoryId)
    .sort(
      (a, b) =>
        Number(b.data.featured) - Number(a.data.featured) ||
        a.data.name.localeCompare(b.data.name),
    );
---

<section class="py-6">
  <h1 class="text-4xl font-bold tracking-tight">awesome-agent-stack</h1>
  <p class="mt-3 max-w-2xl text-lg text-[var(--aas-muted)]">{t('site.tagline')}</p>
</section>

<section id="categories" class="mt-8 space-y-12">
  {
    categories.map((cat) => {
      const items = byCategory(cat.id);
      if (items.length === 0) return null;
      return (
        <div>
          <div class="border-b border-[var(--aas-border)] pb-2">
            <h2 class="text-2xl font-semibold">{cat.label[lang]}</h2>
            <p class="mt-1 text-sm text-[var(--aas-muted)]">{cat.description[lang]}</p>
          </div>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            {items.map((e) => (
              <StackCard
                slug={slugOf(e)}
                lang={lang}
                name={e.data.name}
                description={e.data.description}
                tags={e.data.tags}
                pricing={e.data.pricing}
                license={e.data.license}
                logo={e.data.logo}
              />
            ))}
          </div>
        </div>
      );
    })
  }
</section>
