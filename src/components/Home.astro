---
import { getRelativeLocaleUrl } from 'astro:i18n';
import StackCard from './StackCard.astro';
import ChevronDown from './ChevronDown.astro';
import { rootCategories, descendantIds } from '../data/categories';
import { getStacks, slugOf } from '../lib/stacks';
import { getRepoStats, stalenessOf } from '../lib/github';
import { pricingTags } from '../lib/pricing';
import { useTranslations, pricingLabels, licenseLabel, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const entries = await getStacks(lang);

// Default order is alphabetical (matches the client's default sort, so no flash).
// Group by top-level category, rolling up every subcategory in its subtree.
const byCategory = (categoryId: string) => {
  const ids = new Set(descendantIds(categoryId));
  return entries
    .filter((e) => ids.has(e.data.category))
    .sort((a, b) => a.data.name.localeCompare(b.data.name));
};

// Filter facet options, derived from the data.
const pricingOrder = ['completely-free', 'open-source', 'free-tier', 'paid', 'free'];
const usedPricing = new Set<string>(entries.flatMap((e) => pricingTags(e.data.pricing)));

// "Last updated" facet, from each open-source tool's release age. A tool 1y+
// stale also matches the milder 6m+ option, so stale entries seed both tokens.
const statsList = await Promise.all(entries.map((e) => getRepoStats(e.data.repo)));
const usedStaleness = new Set<string>();
entries.forEach((e, i) => {
  if (!e.data.pricing.includes('open-source')) return;
  const s = stalenessOf(statsList[i]?.releasedAt);
  if (s === 'stale') usedStaleness.add('stale').add('aging');
  else if (s === 'aging') usedStaleness.add('aging');
});

const langSet = new Set(
  entries.flatMap((e) =>
    (e.data.language ?? '')
      .split('/')
      .map((s) => s.trim())
      .filter(Boolean),
  ),
);
const facets = [
  {
    key: 'pricing',
    label: t('detail.pricing'),
    options: pricingOrder
      .filter((p) => usedPricing.has(p))
      .map((p) => ({ value: p, label: pricingLabels[lang][p] ?? p })),
  },
  {
    key: 'license',
    label: t('detail.license'),
    options: [...new Set(entries.map((e) => e.data.license).filter(Boolean))]
      .sort()
      .map((l) => ({ value: l as string, label: licenseLabel(lang, l as string) })),
  },
  {
    key: 'language',
    label: t('detail.language'),
    options: [...langSet].sort().map((l) => ({ value: l, label: l })),
  },
  {
    key: 'updated',
    label: t('filter.updated'),
    options: [
      { value: 'aging', label: t('meta.aging') },
      { value: 'stale', label: t('meta.stale') },
    ].filter((o) => usedStaleness.has(o.value)),
  },
].filter((f) => f.options.length > 0);

const sortOptions = [
  { key: 'alpha', label: t('sort.alpha') },
  { key: 'recent', label: t('sort.recent') },
  { key: 'stars', label: t('sort.stars') },
];

const summaryClass =
  'flex items-center gap-1.5 rounded-lg border border-[var(--aas-border)] bg-[var(--aas-panel)] px-3 py-1.5 text-sm text-[var(--aas-text)]';
const menuClass =
  'absolute left-0 z-10 mt-1 max-h-72 min-w-[12rem] overflow-y-auto rounded-lg border border-[var(--aas-border)] bg-[var(--aas-panel)] p-1 shadow-lg';
---

<section class="py-6">
  <h1 class="text-4xl font-bold tracking-tight">awesome-agent-stack</h1>
  <p class="mt-3 max-w-2xl text-lg text-[var(--aas-muted)]">{t('site.tagline')}</p>
</section>

{/* Search · filter · sort controls (client-side) */}
<div id="categories" class="mt-6 flex flex-col gap-3" data-controls>
  <input
    type="search"
    data-search-input
    placeholder={t('search.placeholder')}
    aria-label={t('search.placeholder')}
    class="w-full rounded-lg border border-[var(--aas-border)] bg-[var(--aas-panel)] px-3.5 py-2.5 text-sm text-[var(--aas-text)] outline-none placeholder:text-[var(--aas-muted)] focus:border-[var(--aas-accent)]"
  />

  <div class="flex flex-wrap items-center gap-2">
    {
      facets.map((f) => (
        <details class="aas-dd">
          <summary class={summaryClass}>
            {f.label}
            <span data-facet-count={f.key} hidden class="aas-pricing rounded px-1.5 text-xs" />
            <ChevronDown class="text-[var(--aas-muted)]" />
          </summary>
          <ul class={menuClass}>
            {f.options.map((o) => (
              <li>
                <label class="flex cursor-pointer items-center gap-2 rounded px-2 py-1.5 text-sm hover:bg-[var(--aas-tint)]">
                  <input type="checkbox" data-facet={f.key} value={o.value} class="aas-check" />
                  {o.label}
                </label>
              </li>
            ))}
          </ul>
        </details>
      ))
    }

    <details class="aas-dd sm:ml-auto">
      <summary class={summaryClass}>
        <span class="text-[var(--aas-muted)]">{t('sort.label')}:</span>
        <span data-sort-label>{sortOptions[0].label}</span>
        <ChevronDown class="text-[var(--aas-muted)]" />
      </summary>
      <ul class={menuClass}>
        {
          sortOptions.map((s, i) => (
            <li>
              <button
                type="button"
                data-sort={s.key}
                aria-current={i === 0 ? 'true' : 'false'}
                class="flex w-full items-center justify-between gap-2 rounded px-2 py-1.5 text-left text-sm hover:bg-[var(--aas-tint)] aria-[current=true]:font-semibold aria-[current=true]:text-[var(--aas-accent)]"
              >
                {s.label}
                <span data-check aria-hidden="true" class="opacity-0">
                  ✓
                </span>
              </button>
            </li>
          ))
        }
      </ul>
    </details>

    <button
      type="button"
      data-clear
      hidden
      class="rounded-lg px-2.5 py-1.5 text-sm text-[var(--aas-muted)] hover:text-[var(--aas-accent)]"
    >
      {t('filter.clear')}
    </button>
  </div>
</div>

<p data-no-results hidden class="mt-10 text-center text-[var(--aas-muted)]">{t('results.none')}</p>

<section class="mt-8 space-y-12">
  {
    rootCategories.map((cat) => {
      const items = byCategory(cat.id);
      if (items.length === 0) return null;
      return (
        <div data-section>
          <div class="pb-1">
            <h2 class="text-2xl font-semibold">
              <a
                href={getRelativeLocaleUrl(lang, `categories/${cat.id}/`)}
                class="text-[var(--aas-text)] no-underline hover:text-[var(--aas-accent)]"
              >
                {cat.label[lang]}
                <span class="text-[var(--aas-muted)]"> &nearr;</span>
              </a>
            </h2>
            <p class="mt-1 text-sm text-[var(--aas-muted)]">{cat.description[lang]}</p>
          </div>
          <div class="mt-5 grid gap-4 sm:grid-cols-2" data-grid>
            {items.map((e) => (
              <StackCard
                slug={slugOf(e)}
                lang={lang}
                name={e.data.name}
                description={e.data.description}
                tags={e.data.tags}
                pricing={e.data.pricing}
                license={e.data.license}
                language={e.data.language}
                category={e.data.category}
                logo={e.data.logo}
                repo={e.data.repo}
                version={e.data.version}
                deprecated={e.data.deprecated}
              />
            ))}
          </div>
        </div>
      );
    })
  }
</section>

<script>
  const root = document.querySelector<HTMLElement>('[data-controls]');
  if (root) {
    const input = root.querySelector<HTMLInputElement>('[data-search-input]')!;
    const boxes = Array.from(root.querySelectorAll<HTMLInputElement>('input[data-facet]'));
    const sortBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-sort]'));
    const sortLabel = root.querySelector<HTMLElement>('[data-sort-label]')!;
    const clearBtn = root.querySelector<HTMLButtonElement>('[data-clear]')!;
    const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-section]'));
    const noResults = document.querySelector<HTMLElement>('[data-no-results]')!;
    let sort = 'alpha';

    const alpha = (a: HTMLElement, b: HTMLElement) =>
      (a.dataset.name ?? '').localeCompare(b.dataset.name ?? '');

    function comparator(a: HTMLElement, b: HTMLElement) {
      if (sort === 'recent') {
        const ad = a.dataset.date ?? '';
        const bd = b.dataset.date ?? '';
        if (!ad && !bd) return alpha(a, b);
        if (!ad) return 1;
        if (!bd) return -1;
        return bd.localeCompare(ad);
      }
      if (sort === 'stars') {
        const ah = a.dataset.stars !== '';
        const bh = b.dataset.stars !== '';
        if (!ah && !bh) return alpha(a, b);
        if (!ah) return -1; // no-star (commercial) first, alphabetically
        if (!bh) return 1;
        return Number(b.dataset.stars) - Number(a.dataset.stars);
      }
      return alpha(a, b);
    }

    function selected(facet: string) {
      return new Set(boxes.filter((b) => b.dataset.facet === facet && b.checked).map((b) => b.value));
    }

    function apply() {
      const q = input.value.trim().toLowerCase();
      const f = {
        pricing: selected('pricing'),
        license: selected('license'),
        language: selected('language'),
        updated: selected('updated'),
      };
      let total = 0;
      for (const section of sections) {
        const grid = section.querySelector<HTMLElement>('[data-grid]')!;
        const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-tool]'));
        let visible = 0;
        for (const card of cards) {
          const ok =
            (!q || (card.dataset.search ?? '').includes(q)) &&
            (!f.pricing.size ||
              (card.dataset.pricing ?? '').split('|').some((v) => f.pricing.has(v))) &&
            (!f.license.size || f.license.has(card.dataset.license ?? '')) &&
            (!f.language.size ||
              (card.dataset.langs ?? '').split('|').some((v) => f.language.has(v))) &&
            (!f.updated.size ||
              (card.dataset.staleness ?? '').split(' ').some((v) => f.updated.has(v)));
          card.hidden = !ok;
          if (ok) visible++;
        }
        cards
          .filter((c) => !c.hidden)
          .sort(comparator)
          .forEach((c) => grid.appendChild(c));
        section.hidden = visible === 0;
        total += visible;
      }
      noResults.hidden = total !== 0;

      // Facet count badges + clear-button visibility.
      let anyFilter = q.length > 0 || sort !== 'alpha';
      for (const facet of ['pricing', 'license', 'language', 'updated']) {
        const n = selected(facet).size;
        const badge = root!.querySelector<HTMLElement>(`[data-facet-count="${facet}"]`)!;
        badge.textContent = String(n);
        badge.hidden = n === 0;
        if (n > 0) anyFilter = true;
      }
      clearBtn.hidden = !anyFilter;
    }

    input.addEventListener('input', apply);
    boxes.forEach((b) => b.addEventListener('change', apply));
    sortBtns.forEach((btn) =>
      btn.addEventListener('click', () => {
        sort = btn.dataset.sort!;
        sortLabel.textContent = btn.textContent!.replace('✓', '').trim();
        sortBtns.forEach((b) => b.setAttribute('aria-current', String(b === btn)));
        btn.closest('details')?.removeAttribute('open');
        apply();
      }),
    );
    clearBtn.addEventListener('click', () => {
      input.value = '';
      boxes.forEach((b) => (b.checked = false));
      sortBtns[0].click();
    });

    apply();
  }
</script>
