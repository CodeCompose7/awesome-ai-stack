---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import StackCard from '../components/StackCard.astro';
import { categories } from '../data/categories';

const entries = await getCollection('stacks');

// Group entries by their category id for sectioned rendering.
const byCategory = (categoryId: string) =>
  entries
    .filter((e) => e.data.category === categoryId)
    .sort((a, b) => Number(b.data.featured) - Number(a.data.featured) || a.data.name.localeCompare(b.data.name));
---

<BaseLayout title="awesome-agent-stack">
  <section class="py-6">
    <h1 class="text-4xl font-bold tracking-tight">awesome-agent-stack</h1>
    <p class="mt-3 max-w-2xl text-lg text-[var(--aas-muted)]">
      A curated stack of the tools and services you actually use to build AI agents —
      each with a detail page and runnable sample code.
    </p>
  </section>

  <section id="categories" class="mt-8 space-y-12">
    {
      categories.map((cat) => {
        const items = byCategory(cat.id);
        if (items.length === 0) return null;
        return (
          <div>
            <div class="border-b border-[var(--aas-border)] pb-2">
              <h2 class="text-2xl font-semibold">{cat.label}</h2>
              <p class="mt-1 text-sm text-[var(--aas-muted)]">{cat.description}</p>
            </div>
            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              {items.map((e) => (
                <StackCard
                  id={e.id}
                  name={e.data.name}
                  description={e.data.description}
                  tags={e.data.tags}
                  pricing={e.data.pricing}
                />
              ))}
            </div>
          </div>
        );
      })
    }
  </section>
</BaseLayout>
