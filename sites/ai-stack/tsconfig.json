{
  "extends": "astro/tsconfigs/strict",
  // The theme's sources are included so `astro check` covers them against
  // THIS site's generated content types and data modules.
  "include": [".astro/types.d.ts", "**/*", "../../packages/core/src/**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@assets/*": ["src/assets/*"],
      "@aas-data/*": ["src/data/*"]
    }
  }
}
